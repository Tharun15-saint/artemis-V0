# Medallion Layer 1 — immutable raw payload store (content-addressable blobs).
# The DB manifest (raw_artifact) is the source of truth; the bytes live here and
# must never enter git (large, and may contain proprietary RRK source documents).
raw_store/

# Database — never upload this (Postgres/Timescale is the source of truth now;
# SQLite files are kept locally only as a migration rollback)
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# Environment variables and API keys — never upload
.env
.env.local
*.env

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtual environment
venv/
env/
.venv/

# OS files
.DS_Store
Thumbs.db

# Cursor AI files (optional — keep if you want)
# .cursor/

# Large / proprietary data files — source documents (tech packs, costing sheets,
# yarn data, RRK invoices) stay LOCAL only; many are buyer-confidential (Walmart).
# Keep them out of git; back them up externally instead. See data/reference/REFERENCE_MANIFEST.md
*.xlsx
*.xls
*.xlsm
*.pdf
*.csv
# Images (tech-pack photos etc. — data, often confidential)
*.jpg
*.jpeg
*.png
*.webp
*.gif

# Database dumps / data backups — never commit (large data; re-creatable)
*backup*.sql
*.dump

# Logs
*.log
