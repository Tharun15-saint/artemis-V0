# NOTE: by the owner's explicit decision (full rights to the data), buyer-confidential
# SOURCE DOCUMENTS (tech packs, costing sheets, yarn data, images, masters) ARE
# committed to this PRIVATE repository for durable backup. Only secrets and files that
# are oversized/re-creatable are excluded below.

# Secrets — NEVER commit (real API keys: FMP, FRED, etc.)
.env
.env.local
*.env

# SQLite databases — old rollback copies; large (>100MB, exceed GitHub limit);
# Postgres/Timescale is the source of truth now.
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# DB dumps / data-backup snapshots — re-creatable from sources+scripts, and some
# exceed GitHub's 100MB per-file hard limit (e.g. the 144MB full dump).
backups/

# Medallion Layer-1 raw blob store — system-managed, content-addressable cache;
# reconstructable, and duplicates the human-readable docs already in data/reference/.
raw_store/

# Python cache / virtualenv
__pycache__/
*.pyc
*.pyo
.pytest_cache/
venv/
env/
.venv/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
